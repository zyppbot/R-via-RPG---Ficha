{
  "entities": {
    "Character": {
      "title": "Character Sheet",
      "description": "A character sheet for the Ruvia RPG system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "title": { "type": "string" },
        "level": { "type": "number" },
        "attributes": {
          "type": "object",
          "properties": {
            "forca": { "type": "number" },
            "destreza": { "type": "number" },
            "vigor": { "type": "number" },
            "intelecto": { "type": "number" },
            "expressao": { "type": "number" },
            "carisma": { "type": "number" }
          }
        },
        "stats": {
          "type": "object",
          "properties": {
            "pv": {
              "type": "object",
              "properties": {
                "current": { "type": "number" },
                "max": { "type": "number" }
              }
            },
            "pm": {
              "type": "object",
              "properties": {
                "current": { "type": "number" },
                "max": { "type": "number" }
              }
            }
          }
        },
        "inventory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        },
        "origin": { "type": "string" },
        "specializations": { "type": "object" },
        "trainingPointsAdjustment": { "type": "number" },
        "pvAdjustment": { "type": "number" },
        "pmAdjustment": { "type": "number" },
        "soulTestsUsed": { "type": "number" },
        "soulTestsAdjustment": { "type": "number" },
        "domains": { "type": "object" },
        "elements": { "type": "object" },
        "skillTraining": { "type": "object" },
        "unlockedSkills": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["userId", "name", "id"]
    }
  },
  "firestore": {
    "/characters/{characterId}": {
      "schema": "Character",
      "description": "Collection of character sheets indexed by character ID."
    }
  }
}
